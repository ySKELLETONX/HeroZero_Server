# /etc/herozero/laravel.env  — variaveis HZ_* do servidor do jogo.
# (O Laravel tambem le server-laravel/.env; use este arquivo p/ o que e sensivel
#  e p/ os servicos systemd que precisam do ambiente — php-fpm com clear_env=no.)

HZ_ENV=production
HZ_STRICT_AUTH=1
HZ_STRICT_SESSION=1
HZ_ALLOWED_ORIGIN=https://your-game-host.example

# Banco (usuario restrito, NAO root).
HZ_DB_HOST=127.0.0.1
HZ_DB_PORT=3306
HZ_DB_NAME=herozero
HZ_DB_USER=herozero
HZ_DB_PASS=troque-por-um-segredo-forte

# Socket em tempo real.
HZ_SOCKET_URL=https://your-game-host.example         # vai ao cliente (urlSocketServer)
HZ_SOCKET_PUSH_URL=http://127.0.0.1:8090/push        # push interno (loopback)
HZ_SOCKET_TOKEN=troque-por-um-segredo-forte          # == HZ_SOCKET_TOKEN do socket.env

# Rate limit de app (defense-in-depth; ajuste sem redeploy).
HZ_RATE_GAME_PER_MIN=300
HZ_RATE_AUTH_PER_MIN=20

# NUNCA em producao: pagamentos falsos.
# HZ_ALLOW_FAKE_PAYMENTS=1
