# /etc/herozero/monitoring.env  — lido por herozero-healthcheck.service
HZ_HEALTH_WEB=https://your-game-host.example/up
HZ_HEALTH_SOCKET=http://127.0.0.1:8090/health
# Webhook de alerta (Slack/Discord/generico). Deixe vazio p/ so logar.
HZ_ALERT_WEBHOOK=
# Opcional: checa o banco tambem.
HZ_DB_HOST=127.0.0.1
HZ_DB_USER=herozero
HZ_DB_PASS=troque-por-um-segredo-forte
HZ_DB_NAME=herozero
